                        "rawQuery": true,
                        "rawSql": "SELECT\r\n  r.name AS \"Camera\",\r\n  SUM(er.energy_kwh) AS \"Consum (kWh)\"\r\nFROM energy_readings er\r\nJOIN devices d ON d.id = er.device_id\r\nJOIN rooms r ON r.id = d.room_id\r\nWHERE er.recorded_at >= NOW() - INTERVAL '24 hours'\r\nGROUP BY r.name\r\nORDER BY 2 DESC",
